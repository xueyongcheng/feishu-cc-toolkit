# Copy to .env and fill in. .env is gitignored — never commit it.

# ---- Outbound proxy for reaching Anthropic (Claude) ----
# The bridge daemon runs WITHOUT proxy (Feishu is a domestic CN service and an
# overseas proxy resets its CONNECT tunnel). This proxy is injected ONLY into
# the `claude` child so it can reach Anthropic. Point it at your local HTTP proxy.
PROXY_HTTP=http://127.0.0.1:6152

# ---- Bridge profile name (matches `lark-channel-bridge --profile`) ----
PROFILE=claude

# ---- Binaries (leave blank to auto-detect via PATH) ----
# Set explicitly if auto-detection picks the wrong one.
CLAUDE_BIN=
LARK_CLI_BIN=
BRIDGE_BIN=
# Prefer a STABLE node path over a version-pinned Cellar path so node upgrades
# don't break the daemon. Blank = installer prefers /opt/homebrew/opt/node@22/bin/node.
NODE_BIN=

# ---- Reference only (not read by these scripts) ----
# Your Feishu app id, used when you run `lark-cli config init`. The app SECRET
# must come from your own secret store, never from this repo.
# FEISHU_BOT_APP_ID=cli_xxxxxxxxxxxxxxxx
